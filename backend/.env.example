# ─── Ticketmaster API ───────────────────────────────────────────
TICKETMASTER_API_KEY=your_ticketmaster_api_key_here
TICKETMASTER_BASE_URL=https://app.ticketmaster.com/discovery/v2

# ─── Cache ───────────────────────────────────────────────────────
# How long (seconds) to cache API responses in-memory
CACHE_TTL_SECONDS=60
# Max number of cached entries
CACHE_MAX_SIZE=500

# ─── Rate Limiting ───────────────────────────────────────────────
# Max requests per minute per IP
RATE_LIMIT_PER_MINUTE=60

# ─── CORS ────────────────────────────────────────────────────────
# Comma-separated list of allowed origins (frontend URL)
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ─── Response Security ───────────────────────────────────────────
# Whether to expose raw Ticketmaster response fields (never true in prod)
EXPOSE_RAW_RESPONSE=false
# Strip internal _links, _embedded fields from responses
STRIP_INTERNAL_FIELDS=true

# ─── App ─────────────────────────────────────────────────────────
APP_ENV=development
APP_DEBUG=false
APP_HOST=0.0.0.0
APP_PORT=8000
